# Required
ANTHROPIC_API_KEY=sk-ant-...

# Choose your notifier: slack | email | console
ARIA_NOTIFIER=console

# Slack (required if ARIA_NOTIFIER=slack)
ARIA_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Email (required if ARIA_NOTIFIER=email)
ARIA_SMTP_HOST=smtp.gmail.com
ARIA_SMTP_PORT=465
ARIA_EMAIL_SENDER=you@gmail.com
ARIA_EMAIL_PASSWORD=your-app-password
ARIA_EMAIL_RECIPIENT=oncall@yourteam.com

# PostgreSQL
ARIA_PG_PASSWORD=notif_pass
ARIA_PG_HOST=localhost
ARIA_PG_PORT=5432
ARIA_PG_DATABASE=notifications
ARIA_PG_USER=notif_user

# Kafka
ARIA_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
ARIA_KAFKA_ENABLED=true
